<?xml version="1.0"?>
<robot name="thesis_ee_model" xmlns:xacro="http://ros.org/wiki/xacro">

  <!--
    thesis_ee_macro.xacro
    Rigid end-effector assembly for the thesis writing task.

    Parts:
      - elbow.STL        : PETG mounting bracket attaching to Gen3 tool flange
      - Full_Assembly.STL: composite writing tool attaching to the elbow

    COORDINATE CONVENTIONS:
      Both STLs are exported from the same SolidWorks assembly with the SW
      origin coincident with the Gen3 tool-flange face (where the elbow bolts
      onto end_effector_link). Per dimensions.pdf:
        SW +Z = along the tool axis, away from the arm (pen direction)
        SW +Y = lateral, toward the assembly box (the 117 mm offset)
        SW +X = small in-plane offset (the 2.88 mm offset)
      Kinova end_effector_link convention (per CLAUDE.md, pen-down posture):
        EE -Y = along the tool axis (pen direction)
      Mapping (proper right-handed rotation, det = +1):
        SW +Z -> EE -Y     SW +Y -> EE +X     SW +X -> EE -Z
      URDF rpy producing this rotation:  rpy="0 1.5707963 -1.5707963"
      Applied to both visuals (and the Full_Assembly collision) at xyz="0 0 0".

    PEN TIP in EE frame (R * (2.88, 117.26, 328.15) mm):
        xyz = (0.11726, -0.32815, -0.00288) m

    MASS PROPERTIES (SolidWorks, full assembly including elbow):
      Total mass = 1566.76 g = 1.567 kg
      CoM (SW frame, mm): X=107.70  Y=120.07  Z=145.15
        -> EE frame: xyz = (0.12007, -0.14515, -0.10770) m
      Inertia at CoM, axis-relabelled SW -> EE:
        Ixx_EE = Lyy_SW = 0.021982
        Iyy_EE = Lzz_SW = 0.005741
        Izz_EE = Lxx_SW = 0.021976
        Ixy_EE = -Lyz_SW = -0.0001843
        Ixz_EE = -Lxy_SW = +0.0000105
        Iyz_EE = +Lxz_SW = -0.0001164
  -->

  <xacro:macro name="load_gripper" params="
    parent
    prefix
    use_fake_hardware:=false
    fake_sensor_commands:=false
    sim_ignition:=false
    sim_isaac:=false
    isaac_joint_commands:=/isaac_joint_commands
    isaac_joint_states:=/isaac_joint_states
    com_port:=/dev/ttyUSB0
    use_internal_bus_gripper_comm:=false
    moveit_active:=false">

    <link name="${prefix}thesis_ee">

      <!-- Elbow bracket: mounts flush on Gen3 tool flange.
           10 mm Z+ offset clears the wrist body; rpy maps SW frame -> EE frame
           with +90 deg yaw to face out from the flange. -->
      <visual>
        <origin xyz="-0.050 -0.050 0.003" rpy="1.5707963 0 1.5707963"/>
        <geometry>
          <mesh filename="package://kortex_description/grippers/thesis_ee/meshes/elbow.STL"
                scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="thesis_ee_petg">
          <color rgba="0.55 0.27 0.07 1.0"/>
        </material>
      </visual>

      <!-- Full assembly writing tool: same SW origin (EE flange), same rotation. -->
      <visual>
        <origin xyz="-0.110 -0.025 -0.202" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://kortex_description/grippers/thesis_ee/meshes/Full_Assembly.STL"
                scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="thesis_ee_grey">
          <color rgba="0.40 0.40 0.40 1.0"/>
        </material>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="0 1.5707963 -1.5707963"/>
        <geometry>
          <mesh filename="package://kortex_description/grippers/thesis_ee/meshes/Full_Assembly.STL"
                scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0.12007 -0.14515 -0.10770" rpy="0 0 0"/>
        <mass value="1.567"/>
        <inertia ixx="0.021982" ixy="-0.0001843" ixz="0.0000105"
                                iyy="0.005741"   iyz="-0.0001164"
                                                 izz="0.021976"/>
      </inertial>
    </link>

    <joint name="${prefix}thesis_ee_joint" type="fixed">
      <parent link="${parent}"/>
      <child  link="${prefix}thesis_ee"/>
      <origin xyz="0 0 0" rpy="0 0 -1.5707963"/>
    </joint>

    <!-- Virtual TCP — required by SRDF chain (base_link → pen_tip) and MoveIt IK -->
    <link name="${prefix}pen_tip"/>
    <joint name="${prefix}pen_tip_joint" type="fixed">
      <parent link="${parent}"/>
      <child  link="${prefix}pen_tip"/>
      <origin xyz="0.11726 -0.32815 -0.00288" rpy="0 0 0"/>
    </joint>

    <!-- Physical endpoint of the writing assembly, measured from bracelet_link.
         Calibrated 2025-05-06 by touching tip to table and reading bracelet_link Z:
           offset_z = table_z - bracelet_z_at_touch = -0.030 - 0.383 = -0.413 m
         Cross-checked at 20 cm above table: -0.416 m (3 mm error, acceptable).
         offset_x from 3.8° bracelet tilt × 0.414 m = -0.027 m.

         Verify after rebuild:
           ros2 run tf2_ros tf2_echo world assembly_tip
         Touch tip to table — Z should read ≈ -0.030 m (table surface).
         Touch tip to a marked XY point — XY should match. -->
    <link name="${prefix}assembly_tip"/>
    <joint name="${prefix}assembly_tip_joint" type="fixed">
      <parent link="bracelet_link"/>
      <child  link="${prefix}assembly_tip"/>
      <origin xyz="-0.027 0.000 -0.414" rpy="0 0 0"/>
    </joint>

  </xacro:macro>
</robot>